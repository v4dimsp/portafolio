---
import translations from '../data/i18n.json';

interface Props {
  title?: string;
}

const { title = 'Vadim S.P – Full Stack Developer' } = Astro.props;
---
<!doctype html>
<html lang="es" data-lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={`Portfolio de ${title} – Full Stack Developer apasionado por construir software limpio y funcional.`} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/placeholder.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

    <!-- i18n: detect language before first paint -->
    <script is:inline define:vars={{ t: translations }}>
      (function () {
        var STORAGE_KEY = 'portfolio-lang';

        function detectLang() {
          var stored = localStorage.getItem(STORAGE_KEY);
          if (stored === 'en' || stored === 'es') return stored;
          var browser = (navigator.language || 'es').toLowerCase();
          return browser.startsWith('en') ? 'en' : 'es';
        }

        function applyLang(lang) {
          document.documentElement.setAttribute('data-lang', lang);
          document.documentElement.setAttribute('lang', lang);
          localStorage.setItem(STORAGE_KEY, lang);

          document.querySelectorAll('[data-i18n]').forEach(function (el) {
            var key = el.getAttribute('data-i18n');
            if (t[lang] && t[lang][key] !== undefined) {
              el.textContent = t[lang][key];
            }
          });

          document.querySelectorAll('[data-lang-btn]').forEach(function (btn) {
            btn.classList.toggle('lang-flag-btn--active', btn.getAttribute('data-lang-btn') === lang);
          });
        }

        window.__setLang = applyLang;
        window.__currentLang = detectLang;

        var initialLang = detectLang();
        document.documentElement.setAttribute('data-lang', initialLang);

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', function () { applyLang(initialLang); });
        } else {
          applyLang(initialLang);
        }
      })();
    </script>
  </head>
  <body>
    <slot />

    <!-- Fixed language flag buttons -->
    <div class="lang-flags" role="group" aria-label="Language / Idioma">
      <button class="lang-flag-btn lang-flag-btn--active" data-lang-btn="es"
        onclick="window.__setLang('es')" title="Español" aria-label="Español">
        <!-- Spain flag -->
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 60 40" width="36" height="24">
          <rect width="60" height="40" fill="#c60b1e"/>
          <rect y="10" width="60" height="20" fill="#ffc400"/>
        </svg>
      </button>
      <button class="lang-flag-btn" data-lang-btn="en"
        onclick="window.__setLang('en')" title="English" aria-label="English">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 60 30" width="36" height="24">
          <rect width="60" height="30" fill="#012169"/>

          <polygon points="0,0 8,0 60,22.5 60,30 52,30 0,7.5" fill="white"/>
          <polygon points="60,0 52,0 0,22.5 0,30 8,30 60,7.5" fill="white"/>

          <polygon points="0,0 4,0 60,26 60,30 56,30 0,4" fill="#C8102E"/>
          <polygon points="60,0 56,0 0,26 0,30 4,30 60,4" fill="#C8102E"/>

          <rect x="23" y="0" width="14" height="30" fill="white"/>
          <rect x="0" y="8" width="60" height="14" fill="white"/>
          <rect x="26" y="0" width="8" height="30" fill="#C8102E"/>
          <rect x="0" y="11" width="60" height="8" fill="#C8102E"/>

        </svg>
      </button>
    </div>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
