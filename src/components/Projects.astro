---
import projects from '../data/projects.json';
---

<section id="projects">
  <hr class="divider" />
  <div class="container">
    <p class="section-label" data-i18n="section.projects.label">Proyectos</p>
    <h2 class="section-title" data-i18n="section.projects.title">Lo que he construido</h2>

    <div class="projects__grid">
      {projects.map(project => (
        <article class="project-card">
          <div class="project-card__header">
            <div class="project-card__icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <rect x="3" y="3" width="18" height="18" rx="2"/>
                <path d="m9 9 3 3-3 3m4 0h4"/>
              </svg>
            </div>
            {project.status === 'live' && (
              <span class="project-card__badge project-card__badge--live">Live</span>
            )}
            {project.status === 'soon' && (
              <span class="project-card__badge project-card__badge--soon" data-i18n="project.soon">Próximamente en GitHub</span>
            )}
          </div>

          <h3 class="project-card__title">{project.title}</h3>

          <p class="project-card__desc i18n-es">{project.description}</p>
          <p class="project-card__desc i18n-en">{project.description_en}</p>

          <div class="project-card__tags">
            {project.tags.map(tag => (
              <span class="tag">{tag}</span>
            ))}
          </div>

          <div class="project-card__links">
            {project.github && (
              <a href={project.github} target="_blank" rel="noopener" class="project-card__link">
                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/>
                </svg>
                <span data-i18n="project.code">Código</span>
              </a>
            )}
            {project.demo && (
              <a href={project.demo} target="_blank" rel="noopener" class="project-card__link">
                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                  <polyline points="15 3 21 3 21 9"/>
                  <line x1="10" y1="14" x2="21" y2="3"/>
                </svg>
                <span data-i18n="project.demo">Demo</span>
              </a>
            )}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .projects__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(380px, 1fr));
    gap: 20px;
  }

  .project-card {
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 32px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    transition: border-color var(--transition), background var(--transition), box-shadow var(--transition);
  }

  .project-card:hover {
    border-color: rgba(0, 212, 255, 0.4);
    background: var(--bg-elevated);
    box-shadow: 0 0 0 1px rgba(0, 212, 255, 0.08), 0 8px 40px rgba(0, 212, 255, 0.07);
  }

  .project-card__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .project-card__icon {
    color: var(--text-muted);
    transition: color var(--transition);
  }

  .project-card:hover .project-card__icon {
    color: var(--accent);
  }

  .project-card__badge {
    font-size: 11px;
    font-weight: 600;
    padding: 3px 10px;
    border-radius: 99px;
    letter-spacing: 0.05em;
  }

  .project-card__badge--live {
    background: rgba(74, 222, 128, 0.1);
    color: #4ade80;
    border: 1px solid rgba(74, 222, 128, 0.25);
  }

  .project-card__badge--soon {
    background: rgba(0, 212, 255, 0.08);
    color: var(--accent);
    border: 1px solid rgba(0, 212, 255, 0.2);
    opacity: 0.85;
  }

  .project-card__title {
    font-size: 17px;
    font-weight: 600;
    color: var(--text-primary);
    letter-spacing: -0.01em;
  }

  .project-card__desc {
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.75;
    flex: 1;
  }

  .project-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 4px;
  }

  .project-card__links {
    display: flex;
    gap: 16px;
    margin-top: 8px;
    padding-top: 16px;
    border-top: 1px solid var(--border);
  }

  .project-card__link {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    color: var(--text-secondary);
    transition: color var(--transition);
  }

  .project-card__link:hover {
    color: var(--accent);
  }

  @media (max-width: 640px) {
    .projects__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
